{
    "name": "backend",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "seed": "node src/seeders/seed.js",
        "migrate:create": "node-pg-migrate create",
        "migrate:up": "node-pg-migrate up",
        "migrate:down": "node-pg-migrate down",
        "docs": "jsdoc -c jsdoc.json -r src",
        "docs:pdf": "del /f /q documentacion.md documentacion.pdf 2>nul & documentation build src/**/*.js -f md -o documentacion.md && md-to-pdf documentacion.md"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "dependencies": {
        "@faker-js/faker": "^10.3.0",
        "@prisma/client": "6.19.2",
        "archiver": "^7.0.1",
        "bcrypt": "^6.0.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.1.0",
        "node-pg-migrate": "^8.0.4",
        "pg": "^8.18.0"
    },
    "devDependencies": {
        "documentation": "^14.0.3",
        "md-to-pdf": "^5.2.5",
        "nodemon": "^3.1.13",
        "prisma": "6.19.2"
    },
    "jsdoc": {
        "source": {
            "include": [
                "src/controllers",
                "src/services",
                "src/utils",
                "src/middlewares"
            ],
            "includePattern": ".+\\.js(doc|x)?$",
            "excludePattern": "(^|\\/|\\\\)_"
        },
        "opts": {
            "encoding": "utf8",
            "destination": "./docs",
            "recurse": true,
            "template": "node_modules/clean-jsdoc-theme",
            "theme_opts": {
                "default_theme": "dark",
                "title": "Documentación de la API - 3D Models"
            }
        }
    }
}
